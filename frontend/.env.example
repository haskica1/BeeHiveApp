# ─────────────────────────────────────────────────────────────────────────────
# BeeHive Frontend — environment variables
#
# Development:
#   Copy to .env.local and adjust. Vite picks it up automatically.
#   .env.local is git-ignored so secrets stay out of version control.
#
# Production (Vercel):
#   Set these in the Vercel dashboard under Project → Settings → Environment Variables.
#   Do NOT commit a .env.production file — Vercel injects vars at build time.
# ─────────────────────────────────────────────────────────────────────────────

# Full URL of the backend API (including /api suffix).
# • Development: leave commented — Vite proxy handles /api → backend automatically.
# • Vercel: set this to your Render backend URL.
VITE_API_URL=https://beehiveapp-y076.onrender.com/api
